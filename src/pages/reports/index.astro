---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import PageHeader from '../../components/app/PageHeader.astro';
import { Button } from '../../components/ui/Button';
import { ReportsView } from '../../components/reports/ReportsView';
---

<DashboardLayout title="Berichte" crumb="Berichte">
    <PageHeader
        eyebrow="Analyse"
        title="Berichte & Exporte"
        subtitle="Jahresziele, Mittelverwendung und herunterladbare Finanzberichte — transparent und prüfbereit."
    >
        <Button slot="actions" size="md" client:visible>+ Bericht erstellen</Button>
    </PageHeader>

    <ReportsView client:load />
</DashboardLayout>

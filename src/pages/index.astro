---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import PageHeader from '../components/app/PageHeader.astro';
import { Button } from '../components/ui/Button';
import { DashboardView } from '../components/dashboard/DashboardView';
---

<DashboardLayout title="Dashboard" crumb="Dashboard">
    <PageHeader
        eyebrow="Übersicht"
        title="Willkommen zurück, Anvar"
        subtitle="Hier ist der aktuelle Status des Meridian-Fonds — Volumen, Mitglieder und Zahlungen auf einen Blick."
    >
        <Button slot="actions" variant="secondary" size="md" client:visible>Berichte</Button>
        <Button slot="actions" size="md" client:visible>+ Neue Aktion</Button>
    </PageHeader>

    <DashboardView client:load />
</DashboardLayout>

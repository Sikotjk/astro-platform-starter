---
interface Props {
    title: string;
    subtitle?: string;
    eyebrow?: string;
}
const { title, subtitle, eyebrow } = Astro.props;
---

<div class="relative mb-7 overflow-hidden">
    <div class="aurora opacity-70"></div>
    <div class="relative flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
            {
                eyebrow && (
                    <span class="mb-2 inline-flex items-center gap-1.5 rounded-full border border-border bg-card/60 px-2.5 py-1 text-[11px] font-medium uppercase tracking-wider text-muted">
                        {eyebrow}
                    </span>
                )
            }
            <h1 class="text-[26px] font-bold tracking-tight sm:text-[30px]">{title}</h1>
            {subtitle && <p class="mt-1.5 max-w-2xl text-[15px] text-muted">{subtitle}</p>}
        </div>
        <div class="flex shrink-0 items-center gap-2">
            <slot name="actions" />
        </div>
    </div>
</div>

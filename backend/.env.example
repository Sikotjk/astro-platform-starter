# PostgreSQL — z.B. lokal via Docker oder Supabase/Neon (EU-Region wegen DSGVO!)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tj_shipping?schema=public"

# Stripe (Connect + Identity). Test-Keys verwenden.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_IDENTITY_WEBHOOK_SECRET="whsec_..."

# Plattform-Servicegebühr (z.B. 0.15 = 15 %)
PLATFORM_FEE_RATE="0.15"

# Auth — starke, zufällige Secrets erzeugen (min. 16 Zeichen), z.B.:
#   openssl rand -base64 48
# Die App bricht beim Start ab, wenn JWT_ACCESS_SECRET fehlt, ein bekannter
# Platzhalter ("change-me" o.ä.) oder zu kurz ist (Fail-Fast).
JWT_ACCESS_SECRET="REPLACE_WITH_OPENSSL_RAND_BASE64_48"
JWT_REFRESH_SECRET="REPLACE_WITH_ANOTHER_OPENSSL_RAND_BASE64_48"

# Push-Relay (FCM/APNs). Ohne URL nutzt die App den FakePushSender.
PUSH_WEBHOOK_URL=""

# CORS für eine Web-App. Produktion: erlaubte Origins kommagetrennt, z.B.
# CORS_ORIGIN="https://app.example.com". Lokale Entwicklung: jeden localhost-Port
# erlauben (Flutter-Web nutzt einen zufälligen Port):
# CORS_ALLOW_LOCALHOST="true". Mobile Apps brauchen kein CORS.
CORS_ORIGIN=""
CORS_ALLOW_LOCALHOST="false"

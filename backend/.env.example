# PostgreSQL — z.B. lokal via Docker oder Supabase/Neon (EU-Region wegen DSGVO!)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tj_shipping?schema=public"

# Stripe (Connect + Identity). Test-Keys verwenden.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_IDENTITY_WEBHOOK_SECRET="whsec_..."

# Plattform-Servicegebühr (z.B. 0.15 = 15 %)
PLATFORM_FEE_RATE="0.15"

# Auth
JWT_ACCESS_SECRET="change-me"
JWT_REFRESH_SECRET="change-me-too"

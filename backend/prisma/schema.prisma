// ─────────────────────────────────────────────────────────────────────────────
//  P2P-Crowdshipping "Tadschikistan-Route" — Datenbankschema
//  Stack: PostgreSQL + Prisma. Geldbeträge IMMER als Decimal (nie Float).
//  Leitidee:
//    Trip    = Angebot eines Travelers (freier Gepäckplatz auf einer Route)
//    Package = Versandgut eines Senders (inkl. Zoll-Deklaration via PackageItem)
//    Booking = Vertrag + Geld-Anker (Stripe Escrow) + Compliance-Gate
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────── ENUMS ──────────────────────────────────────

enum UserRole {
  SENDER
  TRAVELER
  BOTH
  ADMIN
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
}

enum TripStatus {
  DRAFT
  ACTIVE
  FULLY_BOOKED
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

// Status-Maschine eines Bookings. Erlaubte Übergänge werden in der
// Applikationsschicht erzwungen (siehe backend/src/bookings/booking.machine.ts).
enum BookingStatus {
  REQUESTED // Sender hat angefragt
  ACCEPTED // Traveler hat akzeptiert (noch nicht bezahlt)
  REJECTED // Traveler hat abgelehnt
  PAID // Zahlung autorisiert/eingezogen -> Escrow gehalten
  HANDED_OVER // Paket physisch übergeben (Compliance-Gate passiert)
  IN_TRANSIT // Im Flug
  DELIVERED // Traveler meldet Zustellung
  CONFIRMED // Empfang bestätigt -> Auszahlung an Traveler ausgelöst
  DISPUTED // Streitfall offen
  REFUNDED // An Sender zurückerstattet
  CANCELLED // Vor Übergabe abgebrochen
}

enum PaymentStatus {
  PENDING
  ESCROW_HELD
  RELEASED
  REFUNDED
  FAILED
}

enum CustomsCategory {
  DOCUMENTS
  CLOTHING
  FOOD_DRY
  ELECTRONICS
  MEDICINE
  GIFTS
  COSMETICS
  OTHER
}

// ─────────────────────────────── USER ───────────────────────────────────────

model User {
  id              String  @id @default(cuid())
  email           String  @unique
  phone           String? @unique
  passwordHash    String?
  role            UserRole @default(SENDER)
  firstName       String
  lastName        String
  preferredLocale String  @default("de") // de | tg | ru
  avatarUrl       String?

  // KYC — wir speichern NUR Referenzen/Claims, niemals Ausweis-Rohdaten.
  kycStatus     KycStatus @default(NOT_STARTED)
  kycSessionId  String? // Stripe Identity verification_session id
  kycVerifiedAt DateTime?

  // Stripe Connect
  stripeCustomerId String? // Rolle Sender (Zahler)
  stripeAccountId  String? // Rolle Traveler (Empfänger / Connected Account)
  payoutsEnabled   Boolean @default(false)

  // Denormalisierte Rating-Aggregate (Pflege via Trigger/Service)
  ratingAvg   Float @default(0)
  ratingCount Int   @default(0)

  trips              Trip[]
  packages           Package[]
  bookingsAsSender   Booking[] @relation("SenderBookings")
  bookingsAsTraveler Booking[] @relation("TravelerBookings")
  sentMessages       Message[]
  reviewsWritten     Review[]  @relation("ReviewAuthor")
  reviewsReceived    Review[]  @relation("ReviewTarget")
  savedSearches      SavedSearch[]
  notifications      Notification[]
  deviceTokens       DeviceToken[]
  refreshTokens      RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kycStatus])
}

// Refresh-Token (Rotation): pro Login eine Kette; nur der SHA-256-Hash wird
// gespeichert. Wiederverwendung eines bereits rotierten Tokens gilt als
// Diebstahl-Indikator -> alle Tokens des Nutzers werden widerrufen.
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique // sha256(token), nie der Klartext
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

enum DevicePlatform {
  IOS
  ANDROID
  WEB
}

// Registriertes Push-Token eines Geräts (für FCM/APNs-Versand).
model DeviceToken {
  id       String         @id @default(cuid())
  userId   String
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  token    String         @unique
  platform DevicePlatform

  createdAt DateTime @default(now())

  @@index([userId])
}

// Gespeicherte Suche eines Senders -> löst Benachrichtigungen aus, sobald ein
// passender Trip erstellt wird (Liquidität/Retention).
model SavedSearch {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  originAirport      String?
  destinationAirport String?
  departureFrom      DateTime?
  departureTo        DateTime?
  minFreeKg          Decimal?  @db.Decimal(5, 2)

  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([active])
}

// In-App-Benachrichtigung (z.B. Treffer für eine gespeicherte Suche).
model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type   String // z.B. "TRIP_MATCH"
  tripId String?
  title  String
  body   String

  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

// ─────────────────────────────── TRIP ───────────────────────────────────────

model Trip {
  id        String @id @default(cuid())
  travelerId String
  traveler  User   @relation(fields: [travelerId], references: [id])

  originAirport      String // IATA, z.B. "FRA", "DUS"
  destinationAirport String // z.B. "DYU" (Dushanbe)
  departureGate      String? // deutsches Abflug-Terminal/Gate
  departureAt        DateTime
  arrivalAt          DateTime?

  capacityKgTotal Decimal @db.Decimal(5, 2)
  capacityKgUsed  Decimal @default(0) @db.Decimal(5, 2)
  pricePerKg      Decimal @db.Decimal(10, 2)
  currency        String  @default("EUR")

  acceptedCategories CustomsCategory[]
  notes              String?
  status             TripStatus @default(ACTIVE)

  bookings  Booking[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Composite-Index für den zentralen Such-/Match-Query
  @@index([originAirport, destinationAirport, departureAt, status])
  @@index([travelerId])
}

// ────────────────────────────── PACKAGE ─────────────────────────────────────

model Package {
  id       String @id @default(cuid())
  senderId String
  sender   User   @relation(fields: [senderId], references: [id])

  title            String
  weightKg         Decimal @db.Decimal(5, 2)
  dimensionsCm     String? // "30x20x10"
  declaredValueEur Decimal @db.Decimal(10, 2)

  // Empfänger in TJ
  recipientName  String
  recipientPhone String
  recipientCity  String

  booking   Booking?
  items     PackageItem[] // Zoll-Deklaration
  createdAt DateTime      @default(now())

  @@index([senderId])
}

// Einzelposten der Zoll-Deklaration (digitales Manifest)
model PackageItem {
  id          String          @id @default(cuid())
  packageId   String
  package     Package         @relation(fields: [packageId], references: [id], onDelete: Cascade)
  category    CustomsCategory
  description String // Klartext (mehrsprachig erfassbar)
  quantity    Int             @default(1)
  unitValueEur Decimal        @db.Decimal(10, 2)
  isSealed    Boolean         @default(false) // versiegelt? -> Warnung im Workflow
  photoUrl    String?

  @@index([packageId])
}

// ────────────────────────────── BOOKING ─────────────────────────────────────

model Booking {
  id         String  @id @default(cuid())
  tripId     String
  trip       Trip    @relation(fields: [tripId], references: [id])
  packageId  String  @unique
  package    Package @relation(fields: [packageId], references: [id])
  senderId   String
  sender     User    @relation("SenderBookings", fields: [senderId], references: [id])
  travelerId String
  traveler   User    @relation("TravelerBookings", fields: [travelerId], references: [id])

  status BookingStatus @default(REQUESTED)

  // Preis-Snapshot zum Buchungszeitpunkt (Trip-Preis kann sich später ändern!)
  agreedWeightKg Decimal @db.Decimal(5, 2)
  itemPrice      Decimal @db.Decimal(10, 2) // Traveler-Anteil
  serviceFee     Decimal @db.Decimal(10, 2) // Plattform-Gebühr
  totalAmount    Decimal @db.Decimal(10, 2) // = itemPrice + serviceFee
  currency       String  @default("EUR")

  // Stripe-Anker
  paymentIntentId String?       @unique
  transferId      String? // Auszahlung an Traveler (Connect Transfer)
  paymentStatus   PaymentStatus @default(PENDING)

  // Compliance-Gate
  customsDeclared         Boolean   @default(false)
  travelerAcceptedTermsAt DateTime?

  conversation Conversation?
  messages     Message[]
  statusEvents BookingStatusEvent[]
  reviews      Review[]
  dispute      Dispute?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([senderId])
  @@index([travelerId])
}

enum DisputeStatus {
  OPEN
  RESOLVED_RELEASE // zugunsten des Travelers -> Escrow ausgezahlt
  RESOLVED_REFUND // zugunsten des Senders -> erstattet
}

// Streitfall zu einer Buchung (Admin-/Mediations-Tooling).
model Dispute {
  id        String  @id @default(cuid())
  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  openedById String // userId (Sender oder Traveler)
  reason     String
  status     DisputeStatus @default(OPEN)

  // Auflösung durch einen Admin.
  resolutionNote String?
  resolvedById   String?
  resolvedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// Append-only Audit-Log jedes Statuswechsels (wichtig bei Disputes/Zoll)
model BookingStatusEvent {
  id          String         @id @default(cuid())
  bookingId   String
  booking     Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  fromStatus  BookingStatus?
  toStatus    BookingStatus
  triggeredBy String // userId | "SYSTEM" | "WEBHOOK"
  metadata    Json?
  createdAt   DateTime       @default(now())

  @@index([bookingId, createdAt])
}

// ──────────────────────────────── CHAT ──────────────────────────────────────

model Conversation {
  id        String    @id @default(cuid())
  bookingId String    @unique
  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  messages  Message[]
  createdAt DateTime  @default(now())
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  bookingId      String
  booking        Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  body           String
  attachmentUrl  String?
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// ─────────────────────────────── REVIEW ─────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("ReviewAuthor", fields: [authorId], references: [id])
  targetId  String
  target    User     @relation("ReviewTarget", fields: [targetId], references: [id])
  rating    Int // 1..5
  comment   String?
  createdAt DateTime @default(now())

  @@unique([bookingId, authorId]) // pro Booking max. 1 Review je Richtung
  @@index([targetId])
}

// Idempotenz-Schutz für Stripe-Webhooks (at-least-once delivery!)
model ProcessedWebhookEvent {
  id          String   @id // Stripe event id (evt_...)
  type        String
  processedAt DateTime @default(now())
}
